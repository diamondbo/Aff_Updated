@page "/"
@using FirstServ
@using Alpaca.Markets
@using System.Runtime.CompilerServices
@using System.Diagnostics.Eventing.Reader
@using gcomp
@inject IAlpacaService Alserv

<PageTitle>Home</PageTitle>
<div class="center-header">
       <p>Buying Power: @buyingpower</p>
       <p>Cash: @cashh</p>
       <p>Buying Power: @bp2</p>
</div>
<div class="container">
    <div class="row">
        <div class="col-md-10"></div>
        <div class="col-md-2">
            <div class="card mb-3">
                        <div class="card-body">
                            <h6 class="card-title">Positions</h6>
                            <DataComponentPositions />
                        </div>
            </div>  
            <div class="card mb-3">
                        <div class="card-body">
                            <h6 class="card-title">Orders</h6>
                            <DataComponentOrders />
                        </div>
            </div>

        </div>
    </div>
</div>

@code {
    private decimal? buyingpower, cashh, bp2;
    protected override async Task OnInitializedAsync()
    {
        var account = await Alserv.GetBuyingPower();
        var acce = await Alserv.GetCash();
        var d = await Alserv.GetAccount();
        bp2 = d.BuyingPower;
        buyingpower = account;
        cashh = acce;
    }
}